---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { signals, type Signal } from '../../data/signals';

export async function getStaticPaths() {
  return signals.map(s => ({
    params: { slug: s.slug },
    props: { signal: s },
  }));
}

const { signal } = Astro.props as { signal: Signal };

const sorted = [...signals].sort((a, b) =>
  new Date(b.date).valueOf() - new Date(a.date).valueOf()
);
const idx  = sorted.findIndex(s => s.slug === signal.slug);
const prev = sorted[idx + 1] ?? null;
const next = sorted[idx - 1] ?? null;

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title={signal.title}
  description={signal.signal}
>

  <!-- Header -->
  <div class="container signals-entry-header" id="entry-header">
    <div class="signals-entry-header__top">
      <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap">
        <a href="/signals" class="t-mono link-swap" style="opacity:0.5">← Signals</a>
        <span class="t-mono" style="opacity:0.3">/</span>
        <span class="tag">{signal.source}</span>
      </div>
      <span class="t-mono" style="opacity:0.4">{formatDate(signal.date)}</span>
    </div>
  </div>

  <hr />

  <!-- Hero -->
  <div class="container" id="entry-hero">
    <div class="signals-hero">
      <div class="signals-hero__image">
        <div class="signals-hero__bg">
          <div class="signals-hero__content">
            <h1 class="signals-hero__title">{signal.title}</h1>
            <div class="signals-hero__meta">
              <span class="t-mono">{signal.source} · {signal.author}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <hr />

  <!-- Body + Sidebar -->
  <div class="container signals-entry-body" id="entry-body">

    <div class="signals-body-grid">
      <article class="signals-body-content">
        <p class="t-label" style="opacity:0.35; margin-bottom:0.5rem">Signal</p>
        <blockquote class="signals-signal-block">{signal.signal}</blockquote>

        <p class="t-label" style="opacity:0.35; margin-bottom:0.5rem; margin-top:2.5rem">Summary</p>
        <p class="t-body" style="opacity:0.75; max-width:68ch">{signal.summary}</p>

        <p class="t-label" style="opacity:0.35; margin-bottom:0.5rem; margin-top:2.5rem">Notes</p>
        <ul class="signals-notes">
          {signal.notes.map((note) => <li>{note}</li>)}
        </ul>

        <p class="t-label" style="opacity:0.35; margin-bottom:0.5rem; margin-top:2.5rem">Context</p>
        <p class="t-body" style="opacity:0.75; max-width:68ch">{signal.context}</p>
      </article>

      <aside class="signals-sidebar">
        <div class="signals-sidebar__card">
          <a href={signal.url} target="_blank" rel="noopener noreferrer" class="btn btn--outline" style="width:100%">
            Watch source →
          </a>
          <div class="signals-sidebar__tags">
            <p class="t-label" style="opacity:0.35; margin-bottom:0.5rem">Tags</p>
            <div style="display:flex; gap:0.4rem; flex-wrap:wrap">
              {signal.tags.map((t) => <span class="tag tag--muted">{t}</span>)}
            </div>
          </div>
        </div>
      </aside>
    </div>

  </div>

  <hr />

  <!-- Prev / Next -->
  <div class="container signals-nav" id="signals-nav">
    <div>
      {prev && (
        <a href={`/signals/${prev.slug}`} class="signals-nav__item">
          <span class="t-mono" style="opacity:0.4">← Earlier</span>
          <p class="signals-nav__title">{prev.title}</p>
          <span class="t-mono" style="opacity:0.35">{formatDate(prev.date)}</span>
        </a>
      )}
    </div>
    <div style="text-align:right">
      {next && (
        <a href={`/signals/${next.slug}`} class="signals-nav__item signals-nav__item--right">
          <span class="t-mono" style="opacity:0.4">More recent →</span>
          <p class="signals-nav__title">{next.title}</p>
          <span class="t-mono" style="opacity:0.35">{formatDate(next.date)}</span>
        </a>
      )}
    </div>
  </div>

</BaseLayout>

<style>
  .signals-entry-header {
    padding-top: 3rem;
    padding-bottom: 1.5rem;
  }

  .signals-entry-header__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .signals-entry-body {
    padding-block: var(--space-section);
  }

  .signals-body-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-gap);
    align-items: start;
  }

  .signals-body-content {
    display: flex;
    flex-direction: column;
  }

  .signals-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .signals-sidebar__card {
    border: var(--border-width) solid var(--border);
    padding: var(--space-card);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .signals-sidebar__tags {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .signals-hero {
    margin-block: 2rem 0;
  }

  .signals-hero__image {
    aspect-ratio: 3 / 1;
    overflow: hidden;
  }

  .signals-hero__bg {
    width: 100%;
    height: 100%;
    background: var(--black-native);
    border: var(--border-width) solid var(--border);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
    position: relative;
  }

  .signals-hero__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .signals-hero__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 56px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.1;
    color: var(--text-on-dark);
    margin: 0;
    max-width: 90%;
  }

  .signals-hero__meta {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--size-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-dark);
    opacity: 0.6;
  }

  @media (max-width: 900px) {
    .signals-body-grid {
      grid-template-columns: 1fr;
    }

    .signals-hero__bg {
      padding: 1.5rem;
    }

    .signals-hero__title {
      font-size: clamp(20px, 3vw, 32px);
    }

    .signals-hero__meta {
      gap: 1rem;
      font-size: 10px;
    }
  }

  .signals-signal-block {
    border-left: var(--border-width) solid var(--accent-strong);
    padding-left: 2rem;
    margin-block: 1rem 0;
    font-family: var(--font-display);
    font-size: clamp(20px, 2.2vw, 28px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.3;
    max-width: 60ch;
  }

  .signals-notes {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-block: 1rem;
  }

  .signals-notes li {
    padding-left: 1.5rem;
    position: relative;
    font-family: var(--font-body);
    font-size: var(--size-body);
    line-height: 1.6;
    opacity: 0.75;
  }

  .signals-notes li::before {
    content: '›';
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    opacity: 0.4;
    top: 6px;
  }

  .signals-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-gap);
    padding-block: 3rem;
  }

  .signals-nav__item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.5rem;
    border: var(--border-width) solid var(--border);
    transition: background var(--transition);
  }

  .signals-nav__item:hover { background: var(--surface-elevated); }

  .signals-nav__title {
    font-family: var(--font-display);
    font-size: clamp(16px, 1.4vw, 20px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.25;
    margin-block: 0.25rem;
  }

  .signals-nav__item--right { text-align: right; }

  @media (max-width: 640px) {
    .signals-nav { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { animate } from 'motion';
  const ease = [0.16, 1, 0.3, 1] as const;

  ['entry-header', 'entry-hero', 'entry-body', 'signals-nav'].forEach((id, i) => {
    const el = document.getElementById(id);
    if (el) {
      el.style.opacity = '0';
      animate(el,
        { opacity: [0, 1], transform: ['translateY(14px)', 'translateY(0)'] },
        { duration: 0.5, easing: ease, delay: 0.05 + i * 0.1 }
      );
    }
  });
</script>
