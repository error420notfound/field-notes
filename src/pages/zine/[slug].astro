---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const issues = await getCollection('zine');
  return issues.map(entry => ({
    params: { slug: entry.slug },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formatDate = (d: Date) => d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const allIssues = (await getCollection('zine')).sort((a, b) => b.data.issue - a.data.issue);
const idx  = allIssues.findIndex(e => e.slug === entry.slug);
const prev = allIssues[idx + 1];
const next = allIssues[idx - 1];
---

<BaseLayout
  title={`Issue ${String(entry.data.issue).padStart(2,'0')} — ${entry.data.title}`}
  description={entry.data.thesis}
>

  <!-- Issue cover strip -->
  <div class="zine-cover-strip" id="cover-strip">
    <div class="zine-cover-strip__bg inv-block">
      <div class="container zine-cover-strip__inner">
        <div class="zine-cover-strip__left">
          <p class="t-label" style="opacity:0.4; margin-bottom:0.4rem">
            HS108 / Field Notes — Zine
          </p>
          <p class="t-label" style="color:var(--teal-400); margin-bottom:2rem">
            Issue {String(entry.data.issue).padStart(2,'0')} · {entry.data.season}
          </p>
          <h1 class="t-hero" style="color:var(--text-on-dark)">{entry.data.title}</h1>
        </div>
        <div class="zine-cover-strip__right">
          <div class="zine-cover-strip__issue-num">
            {String(entry.data.issue).padStart(2,'0')}
          </div>
          <div>
            <p class="t-label" style="opacity:0.4; margin-bottom:0.75rem">Theme</p>
            <p class="t-h3" style="font-style:italic; color:var(--text-on-dark); font-family:var(--font-display)">
              {entry.data.theme}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Thesis -->
  <div class="container zine-thesis" id="zine-thesis">
    <p class="zine-thesis__text">{entry.data.thesis}</p>
    <div class="zine-thesis__meta">
      <span class="t-mono" style="opacity:0.35">{formatDate(entry.data.date)}</span>
      {entry.data.status === 'upcoming' && (
        <span class="tag">Upcoming</span>
      )}
    </div>
  </div>

  <hr />

  <!-- Body -->
  <div class="container zine-body" id="zine-body">
    {entry.data.status === 'upcoming' ? (
      <div class="zine-upcoming-notice">
        <p class="t-label" style="opacity:0.4; margin-bottom:0.75rem">In Preparation</p>
        <p class="t-large" style="opacity:0.65">{entry.data.thesis}</p>
        <p class="t-mono" style="opacity:0.4; margin-top:1rem">
          Issue {String(entry.data.issue).padStart(2,'0')} — {entry.data.season} — expected {entry.data.season}
        </p>
      </div>
    ) : (
      <article class="prose zine-prose">
        <Content />
      </article>
    )}
  </div>

  <hr />

  <!-- Issue navigation -->
  <div class="container zine-nav" id="zine-nav">
    <div>
      {prev && (
        <a href={`/zine/${prev.slug}`} class="zine-nav__item">
          <span class="t-mono" style="opacity:0.4">← Issue {String(prev.data.issue).padStart(2,'0')}</span>
          <p class="zine-nav__title">{prev.data.title}</p>
          <span class="t-mono" style="opacity:0.35">{prev.data.season}</span>
        </a>
      )}
    </div>
    <div>
      <a href="/zine" class="btn btn--outline" style="margin-bottom:1rem">All Issues</a>
    </div>
    <div style="text-align:right">
      {next && (
        <a href={`/zine/${next.slug}`} class="zine-nav__item zine-nav__item--right">
          <span class="t-mono" style="opacity:0.4">Issue {String(next.data.issue).padStart(2,'0')} →</span>
          <p class="zine-nav__title">{next.data.title}</p>
          <span class="t-mono" style="opacity:0.35">{next.data.season}</span>
        </a>
      )}
    </div>
  </div>

</BaseLayout>

<style>
  .zine-cover-strip {
    margin-bottom: 0;
  }

  .zine-cover-strip__bg {
    border-bottom: var(--border-width) solid var(--border);
  }

  .zine-cover-strip__inner {
    padding-block: clamp(4rem, 8vw, 7rem);
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: end;
  }

  .zine-cover-strip__left { display: flex; flex-direction: column; }

  .zine-cover-strip__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2rem;
  }

  .zine-cover-strip__issue-num {
    font-family: var(--font-display);
    font-size: clamp(80px, 14vw, 180px);
    font-style: italic;
    font-weight: 400;
    line-height: 1;
    opacity: 0.12;
    color: var(--text-on-dark);
    user-select: none;
  }

  .zine-thesis {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .zine-thesis__text {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 30px);
    font-style: italic;
    font-weight: 400;
    line-height: 1.35;
    max-width: 65ch;
    opacity: 0.75;
  }

  .zine-thesis__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .zine-body {
    padding-block: var(--space-section);
  }

  .zine-prose {
    max-width: 72ch;
    margin-inline: auto;
  }

  .zine-upcoming-notice {
    border: var(--border-width) solid var(--border);
    padding: var(--space-card);
    max-width: 60ch;
  }

  .zine-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    padding-block: 3rem;
    align-items: center;
  }

  .zine-nav__item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.5rem;
    border: var(--border-width) solid var(--border);
    transition: background var(--transition);
  }

  .zine-nav__item:hover { background: var(--surface-elevated); }

  .zine-nav__title {
    font-family: var(--font-display);
    font-size: clamp(17px, 1.6vw, 22px);
    font-style: italic;
    font-weight: 400;
    line-height: 1.2;
    margin-block: 0.2rem;
  }

  .zine-nav__item--right { text-align: right; }

  @media (max-width: 900px) {
    .zine-cover-strip__inner { grid-template-columns: 1fr; }
    .zine-cover-strip__right { align-items: flex-start; }
    .zine-nav { grid-template-columns: 1fr; text-align: left; }
    .zine-nav > div:nth-child(2) { order: -1; }
  }
</style>

<script>
  import { animate } from 'motion';
  const ease = [0.16, 1, 0.3, 1] as const;

  ['cover-strip','zine-thesis','zine-body','zine-nav'].forEach((id, i) => {
    const el = document.getElementById(id);
    if (el) {
      el.style.opacity = '0';
      animate(el,
        { opacity:[0,1], transform:['translateY(16px)','translateY(0)'] },
        { duration:0.55, easing:ease, delay:0.05 + i * 0.12 }
      );
    }
  });
</script>
