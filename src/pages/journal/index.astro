---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allLogs = await getCollection('journal', ({ data }) => !data.draft);
const sorted  = allLogs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const typeLabels: Record<string, string> = {
  'project-log': 'Project Log',
  'reflection':  'Reflection',
  'decision':    'Decision',
  'weekly':      'Weekly',
};

const formatDate = (d: Date) => d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

// Group by year, descending
const byYear: Record<string, typeof sorted> = {};
for (const entry of sorted) {
  const year = entry.data.date.getFullYear().toString();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(entry);
}
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Journal"
  description="A time-based record of how the studio thinks through work — project logs, reflections, and decisions."
>

  <!-- Page header -->
  <div class="container page-header" id="page-header">
    <p class="t-label" style="opacity:0.4">02 — Journal</p>
    <h1 class="t-h1"><em>Process, live</em></h1>
    <p class="t-large" style="opacity:0.55; max-width:55ch; margin-top:0.75rem">
      A time-aware record of studio thinking. Project logs, reflections, and
      decision rationale — lighter and more provisional than the archive.
    </p>
  </div>

  <hr />

  <!-- Entry count -->
  <div class="container" style="padding-block:1.25rem; display:flex; justify-content:flex-end">
    <span class="t-mono" style="opacity:0.4">{sorted.length} entries</span>
  </div>

  <hr />

  <!-- Entry list, grouped by year -->
  <div class="container journal-list" id="journal-list" style="padding-block:var(--space-section)">
    {years.map((year) => (
      <div class="year-group" data-year={year}>
        <div class="year-marker">
          <span class="t-mono year-marker__label">{year}</span>
          <div class="year-marker__rule" role="presentation"></div>
        </div>
        <div class="year-group__entries">
          {byYear[year].map((entry) => (
            <a href={`/journal/${entry.slug}`} class="entry-row">
              <span class="entry-row__type">{typeLabels[entry.data.type]}</span>
              <div class="entry-row__main">
                <p class="entry-row__title">{entry.data.title}</p>
                {entry.data.subtitle && (
                  <p class="entry-row__desc">{entry.data.subtitle}</p>
                )}
              </div>
              <span class="entry-row__date">{formatDate(entry.data.date)}</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

</BaseLayout>

<style>
  .page-header {
    padding-top: 3rem;
    padding-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .journal-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .year-group__entries {
    display: flex;
    flex-direction: column;
  }
</style>

<script>
  import { animate, inView, stagger } from 'motion';
  const ease = [0.16, 1, 0.3, 1] as const;

  const header = document.getElementById('page-header');
  if (header) {
    header.style.opacity = '0';
    animate(header, { opacity:[0,1], transform:['translateY(16px)','translateY(0)'] }, { duration:0.5, easing:ease, delay:0.08 });
  }

  document.querySelectorAll<HTMLElement>('.year-group').forEach(group => {
    const rows = group.querySelectorAll('.entry-row');
    rows.forEach(r => { (r as HTMLElement).style.opacity = '0'; });
    inView(group, () => {
      animate(rows as NodeListOf<Element>,
        { opacity:[0,1], transform:['translateY(12px)','translateY(0)'] },
        { duration:0.4, easing:ease, delay:stagger(0.05) }
      );
    }, { amount: 0.05 });
  });
</script>
