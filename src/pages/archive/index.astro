---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('archive');
const sorted     = allEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const types = ['all', 'reading', 'signal', 'application', 'calibration'] as const;

const typeLabels: Record<string, string> = {
  all: 'All',
  reading: 'Reading',
  signal: 'Signal',
  application: 'Application',
  calibration: 'Calibration',
};

const formatDate = (d: Date) => d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

// Group by year, descending
const byYear: Record<string, typeof sorted> = {};
for (const entry of sorted) {
  const year = entry.data.date.getFullYear().toString();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(entry);
}
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Archive"
  description="A curated repository of high-value thinking — readings, signals, applications, and calibration logs."
>

  <!-- Page header -->
  <div class="container page-header" id="page-header">
    <p class="t-label" style="opacity:0.4">01 — Archive</p>
    <h1 class="t-h1"><em>Curated thinking</em></h1>
    <p class="t-large" style="opacity:0.55; max-width:55ch; margin-top:0.75rem">
      Readings, signals, applications, and calibration notes. Non-linear, searchable,
      accumulated over time.
    </p>
  </div>

  <hr />

  <!-- Filter bar + count -->
  <div class="container" style="padding-block:1.25rem; display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap">
    <div class="filter-bar" id="filter-bar" role="tablist">
      {types.map((t) => (
        <button
          class={`filter-bar__item ${t === 'all' ? 'active' : ''}`}
          data-type={t}
          role="tab"
          aria-selected={t === 'all'}
        >
          {typeLabels[t]}
        </button>
      ))}
    </div>
    <span class="t-mono" style="opacity:0.4" id="entry-count">{sorted.length} entries</span>
  </div>

  <hr />

  <!-- Entry list, grouped by year -->
  <div class="container archive-list" id="archive-list" style="padding-block:var(--space-section)">
    {years.map((year) => (
      <div class="year-group" data-year={year}>
        <div class="year-marker">
          <span class="t-mono year-marker__label">{year}</span>
          <div class="year-marker__rule" role="presentation"></div>
        </div>
        <div class="year-group__entries">
          {byYear[year].map((entry) => (
            <a
              href={`/archive/${entry.slug}`}
              class="entry-row"
              data-type={entry.data.type}
            >
              <span class="entry-row__type">{typeLabels[entry.data.type]}</span>
              <div class="entry-row__main">
                <p class="entry-row__title">{entry.data.title}</p>
                <p class="entry-row__desc">{entry.data.thesis}</p>
              </div>
              <span class="entry-row__date">{formatDate(entry.data.date)}</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

</BaseLayout>

<style>
  .page-header {
    padding-top: 3rem;
    padding-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .archive-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .year-group__entries {
    display: flex;
    flex-direction: column;
  }
</style>

<script>
  import { animate, inView, stagger } from 'motion';
  const ease = [0.16, 1, 0.3, 1] as const;

  // Page header entrance
  const header = document.getElementById('page-header');
  if (header) {
    header.style.opacity = '0';
    animate(header, { opacity:[0,1], transform:['translateY(16px)','translateY(0)'] }, { duration:0.5, easing:ease, delay:0.08 });
  }

  // Row stagger on scroll
  document.querySelectorAll<HTMLElement>('.year-group').forEach(group => {
    const rows = group.querySelectorAll('.entry-row');
    rows.forEach(r => { (r as HTMLElement).style.opacity = '0'; });
    inView(group, () => {
      animate(rows as NodeListOf<Element>,
        { opacity:[0,1], transform:['translateY(12px)','translateY(0)'] },
        { duration:0.4, easing:ease, delay:stagger(0.05) }
      );
    }, { amount: 0.05 });
  });

  // Filter logic
  const filterBar  = document.getElementById('filter-bar');
  const countLabel = document.getElementById('entry-count');
  const allRows    = document.querySelectorAll<HTMLElement>('.entry-row');
  const allGroups  = document.querySelectorAll<HTMLElement>('.year-group');

  filterBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.filter-bar__item') as HTMLButtonElement | null;
    if (!btn) return;

    filterBar.querySelectorAll('.filter-bar__item').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const type = btn.dataset.type!;
    let visible = 0;

    allRows.forEach(row => {
      const show = type === 'all' || row.dataset.type === type;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Hide year groups that have no visible entries
    allGroups.forEach(group => {
      const hasVisible = Array.from(group.querySelectorAll<HTMLElement>('.entry-row'))
        .some(r => r.style.display !== 'none');
      group.style.display = hasVisible ? '' : 'none';
    });

    if (countLabel) countLabel.textContent = `${visible} entr${visible === 1 ? 'y' : 'ies'}`;
  });
</script>
